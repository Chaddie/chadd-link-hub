# Neon / Postgres — pooled connection string
DATABASE_URL="postgresql://user:pass@host/neondb?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Used by prisma/seed.ts to create the first admin (optional on first seed)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me"

# Public site URL (optional — used for share links and canonical URLs; falls back to request host in dev)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Contact form — SMTP (required to send from /contact)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
# Optional override (default: contact+site@nathanchadwick.com)
CONTACT_TO_EMAIL="contact+site@nathanchadwick.com"
